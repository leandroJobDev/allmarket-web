{
  "version": 2,
  "buildCommand": "npm run build:all",
  "outputDirectory": "dist",
  "headers": [
    {
      "source": "**/*.@(js|mjs)",
      "headers": [
        { "key": "Content-Type", "value": "application/javascript; charset=utf-8" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/notas-mfe/:path*", "destination": "/apps/notas_mfe/:path*" },
    { "source": "/analise-mfe/:path*", "destination": "/apps/analise_mfe/:path*" },
    { "source": "/comparador-mfe/:path*", "destination": "/apps/comparador_mfe/:path*" },
    { "source": "/listas-mfe/:path*", "destination": "/apps/listas_mfe/:path*" },
    { "source": "/:path((?!.*\\.).*)","destination": "/apps/allmarket/index.html" },
    { "source": "/:path*", "destination": "/apps/allmarket/:path*" }
  ]
}
