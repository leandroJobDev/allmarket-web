{
  "name": "allmarket",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "app",
  "sourceRoot": "apps/allmarket/src",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/angular:webpack-browser",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/allmarket",
        "index": "apps/allmarket/src/index.html",
        "main": "apps/allmarket/src/main.ts",
        "tsConfig": "apps/allmarket/tsconfig.app.json",
        "assets": [
          "apps/allmarket/src/favicon.ico",
          "apps/allmarket/src/assets"
        ],
        "styles": ["apps/allmarket/src/styles.css"],
        "customWebpackConfig": {
          "path": "apps/allmarket/webpack.config.ts"
        }
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "1mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "4kb",
              "maximumError": "8kb"
            }
          ],
          "outputHashing": "all",
          "customWebpackConfig": {
            "path": "apps/allmarket/webpack.prod.config.ts"
          },
          "fileReplacements": [
            {
              "replace": "libs/shared/src/app/environments/environment.ts",
              "with": "libs/shared/src/app/environments/environment.prod.ts"
            }
          ],
          "optimization": true,
          "buildOptimizer": true
        },
        "development": {
          "buildOptimizer": false,
          "optimization": false,
          "vendorChunk": true,
          "extractLicenses": false,
          "sourceMap": true,
          "namedChunks": true
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "continuous": true,
      "executor": "@nx/angular:dev-server",
      "configurations": {
        "production": {
          "buildTarget": "allmarket:build:production"
        },
        "development": {
          "buildTarget": "allmarket:build:development"
        }
      },
      "defaultConfiguration": "development",
      "options": {
        "publicHost": "http://localhost:4200"
      }
    },
    "extract-i18n": {
      "executor": "@angular-devkit/build-angular:extract-i18n",
      "options": {
        "buildTarget": "allmarket:build"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "apps/allmarket/jest.config.cts",
        "tsConfig": "apps/allmarket/tsconfig.spec.json"
      }
    },
    "serve-static": {
      "continuous": true,
      "executor": "@nx/web:file-server",
      "defaultConfiguration": "production",
      "options": {
        "buildTarget": "allmarket:build",
        "watch": false
      },
      "configurations": {
        "development": {
          "buildTarget": "allmarket:build:development"
        },
        "production": {
          "buildTarget": "allmarket:build:production"
        }
      }
    }
  }
}
