{
  "hosting": [
    {
      "target": "shell-oficial",
      "public": "dist/apps/allmarket",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "headers": [
        {
          "source": "**/*.js",
          "headers": [
            {
              "key": "Content-Type",
              "value": "application/javascript"
            }
          ]
        },
        {
          "source": "**/*.mjs",
          "headers": [
            {
              "key": "Content-Type",
              "value": "application/javascript"
            }
          ]
        }
      ],
      "rewrites": [{ "source": "**", "destination": "/index.html" }]
    },
    {
      "target": "notas-mfe",
      "public": "dist/apps/notas_mfe",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
