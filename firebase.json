{
  "version": 2,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/notas-mfe/(.*)", "destination": "/dist/apps/notas_mfe/$1" },
    { "source": "/analise-mfe/(.*)", "destination": "/dist/apps/analise_mfe/$1" },
    { "source": "/comparador-mfe/(.*)", "destination": "/dist/apps/comparador_mfe/$1" },
    { "source": "/listas-mfe/(.*)", "destination": "/dist/apps/listas_mfe/$1" },
    { "source": "/((?!.*\\.).*)", "destination": "/dist/apps/allmarket/index.html" },
    { "source": "/(.*)", "destination": "/dist/apps/allmarket/$1" }
  ]
}