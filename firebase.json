{
  "hosting": [
    {
      "target": "shell-oficial",
      "public": "dist/apps/allmarket",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "rewrites": [{ "source": "**", "destination": "/index.html" }]
    },
    {
      "target": "notas-mfe",
      "public": "dist/apps/notas_mfe",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "headers": [{ "source": "/**", "headers": [{ "key": "Access-Control-Allow-Origin", "value": "*" }] }],
      "rewrites": [{ "source": "**", "destination": "/index.html" }]
    },
    {
      "target": "analise-mfe",
      "public": "dist/apps/analise_mfe",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "headers": [{ "source": "/**", "headers": [{ "key": "Access-Control-Allow-Origin", "value": "*" }] }],
      "rewrites": [{ "source": "**", "destination": "/index.html" }]
    },
    {
      "target": "comparador-mfe",
      "public": "dist/apps/comparador_mfe",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "headers": [{ "source": "/**", "headers": [{ "key": "Access-Control-Allow-Origin", "value": "*" }] }],
      "rewrites": [{ "source": "**", "destination": "/index.html" }]
    },
    {
      "target": "listas-mfe",
      "public": "dist/apps/listas_mfe",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "headers": [{ "source": "/**", "headers": [{ "key": "Access-Control-Allow-Origin", "value": "*" }] }],
      "rewrites": [{ "source": "**", "destination": "/index.html" }]
    }
  ]
}